<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JITU Admin — Login</title>
    <script src="https://unpkg.com/@tailwindcss/browser@4"></script>
</head>
<body class="min-h-screen bg-[#F4F7FE] flex items-center justify-center p-4">

    <div class="w-full max-w-md space-y-8">
        <!-- Logo & Header -->
        <div class="text-center">
            <div class="inline-flex w-16 h-16 bg-gradient-to-r from-[#FBCA24] to-[#FBBF24] text-white rounded-2xl items-center justify-center shadow-lg shadow-[#FBBF24]/20 mb-4 font-black text-2xl">
                JT
            </div>
            <h1 class="text-2xl font-black text-zinc-900 tracking-tight uppercase">JITU ADMIN ACCESS</h1>
            <p class="text-xs text-zinc-500 mt-1">Otorisasi Kunci Akses Layanan Operasional UMKM</p>
        </div>

        <!-- Form Card -->
        <div class="bg-white border border-zinc-200/60 rounded-3xl p-8 shadow-md space-y-6">
            <% if (error) { %>
            <div class="px-4 py-3 bg-red-50 border border-red-200 rounded-xl text-xs text-red-600 font-semibold flex items-center gap-2">
                <span>⚠️</span>
                <span><%= error %></span>
            </div>
            <% } %>

            <form method="POST" action="/admin/login" class="space-y-5">
                <div class="space-y-2">
                    <label class="block text-[10px] font-bold text-zinc-400 uppercase tracking-wider pl-1">ADMIN SECRET KEY</label>
                    <input
                        type="password"
                        name="secret_key"
                        placeholder="Masukkan kunci rahasia admin..."
                        required
                        autofocus
                        class="w-full bg-zinc-50 border border-zinc-200 rounded-2xl py-3.5 px-5 text-sm text-zinc-800 outline-none focus:border-[#FBBF24] transition-all placeholder:text-zinc-400"
                    />
                </div>

                <button
                    type="submit"
                    class="w-full bg-gradient-to-r from-[#FBCA24] to-[#FBBF24] text-white font-black py-4 rounded-2xl active:scale-[0.98] transition-all cursor-pointer text-xs uppercase tracking-wider shadow-sm"
                >
                    OTORISASI & MASUK
                </button>
            </form>
        </div>

        <p class="text-center text-[10px] text-zinc-400">
            Akses sistem ini dipantau secara internal. Pelanggaran akan dilaporkan secara otomatis.
        </p>
    </div>

</body>
</html>
