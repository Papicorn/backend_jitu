<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JITU Admin — Login</title>
    <script src="https://unpkg.com/@tailwindcss/browser@4"></script>
</head>
<body class="min-h-screen bg-[#F4F7FE] flex items-center justify-center p-4">

    <div class="w-full max-w-sm">
        <!-- Logo area -->
        <div class="text-center mb-10">
            <div class="inline-flex w-16 h-16 bg-[#FFCA40] rounded-3xl items-center justify-center shadow-xl mb-4 transform rotate-6">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
            </div>
            <h1 class="text-2xl font-bold text-zinc-900">Admin Access</h1>
            <p class="text-sm text-zinc-500 mt-1">JITU Activation Panel</p>
        </div>

        <!-- Card -->
        <div class="bg-white rounded-3xl shadow-xl p-8 border border-zinc-100">
            <% if (error) { %>
            <div class="mb-5 px-4 py-3 bg-red-50 border border-red-200 rounded-2xl text-sm text-red-600 font-medium">
                ⚠️ <%= error %>
            </div>
            <% } %>

            <form method="POST" action="/admin/login" class="space-y-5">
                <div>
                    <label class="block text-xs font-bold text-zinc-500 uppercase tracking-wider mb-2">Admin Secret Key</label>
                    <input
                        type="password"
                        name="secret_key"
                        placeholder="Masukkan Secret Key"
                        required
                        autofocus
                        class="w-full bg-zinc-50 border border-zinc-200 rounded-2xl py-4 px-5 text-sm outline-none focus:ring-2 focus:ring-[#FFCA40] transition-all"
                    />
                </div>

                <button
                    type="submit"
                    class="w-full bg-zinc-900 text-white font-bold py-4 rounded-2xl hover:bg-zinc-700 active:scale-[0.98] transition-all shadow-lg cursor-pointer"
                >
                    Masuk ke Admin Panel
                </button>
            </form>
        </div>

        <p class="text-center text-xs text-zinc-400 mt-6">
            Akses terbatas. Hubungi sistem administrator.
        </p>
    </div>

</body>
</html>
