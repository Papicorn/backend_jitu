<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JITU Admin - Control Panel</title>
    <script src="https://unpkg.com/@tailwindcss/browser@4"></script>
    <style>
        .scrollbar-hide::-webkit-scrollbar {
            display: none;
        }
        .scrollbar-hide {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
</head>

<body class="bg-[#F4F7FE] text-zinc-800 font-sans min-h-screen selection:bg-[#FFCA40] selection:text-zinc-950">

    <div class="flex flex-col md:flex-row min-h-screen">
        
        <!-- Sidebar Navigation (Desktop) -->
        <aside class="w-full md:w-80 bg-white text-zinc-800 flex flex-col justify-between p-6 border-b md:border-b-0 md:border-r border-zinc-200/60 shrink-0">
            <div class="space-y-8">
                <!-- Brand / Logo -->
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-3.5">
                        <div class="w-12 h-12 bg-gradient-to-r from-[#FBCA24] to-[#FBBF24] text-white rounded-2xl flex items-center justify-center font-black text-2xl shadow-lg shadow-[#FBBF24]/20">
                            JT
                        </div>
                        <div>
                            <h1 class="text-sm font-black tracking-wider text-zinc-900 uppercase">JITU PANEL</h1>
                            <p class="text-[10px] text-[#FBBF24] font-extrabold uppercase">OPERASIONAL UMKM</p>
                        </div>
                    </div>
                    <!-- Mobile Logout Trigger -->
                    <a href="/admin/logout" class="md:hidden text-[10px] text-zinc-500 hover:text-red-500 font-bold px-3 py-1.5 rounded-xl bg-zinc-50 border border-zinc-200 transition-all">
                        LOGOUT
                    </a>
                </div>

                <!-- Navigation Tabs (Sidebar items) -->
                <nav class="flex flex-row md:flex-col gap-2 overflow-x-auto md:overflow-visible pb-3 md:pb-0 scrollbar-hide border-b border-zinc-200/60 md:border-b-0">
                    <button onclick="switchTab('activation')" id="tab-activation"
                        class="w-auto md:w-full text-left py-3.5 px-5 rounded-2xl text-xs font-black uppercase tracking-wider transition-all duration-200 flex items-center gap-3.5 cursor-pointer whitespace-nowrap bg-gradient-to-r from-[#FBCA24] to-[#FBBF24] text-white shadow-md">
                        <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                            <line x1="8" y1="21" x2="16" y2="21"/>
                            <line x1="12" y1="17" x2="12" y2="21"/>
                        </svg>
                        <span>Device & Aktivasi</span>
                    </button>
                    <button onclick="switchTab('payments')" id="tab-payments"
                        class="w-auto md:w-full text-left py-3.5 px-5 rounded-2xl text-xs font-black uppercase tracking-wider text-zinc-400 hover:text-zinc-800 hover:bg-zinc-55 transition-all duration-200 flex items-center gap-3.5 cursor-pointer whitespace-nowrap">
                        <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                            <rect x="2" y="4" width="20" height="12" rx="2"/>
                            <circle cx="12" cy="10" r="2"/>
                            <path d="M7 10h.01M17 10h.01"/>
                        </svg>
                        <span>Antrean Beli</span>
                    </button>
                    <button onclick="switchTab('users')" id="tab-users"
                        class="w-auto md:w-full text-left py-3.5 px-5 rounded-2xl text-xs font-black uppercase tracking-wider text-zinc-400 hover:text-zinc-800 hover:bg-zinc-55 transition-all duration-200 flex items-center gap-3.5 cursor-pointer whitespace-nowrap">
                        <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                            <circle cx="9" cy="7" r="4"/>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                        </svg>
                        <span>Database User</span>
                    </button>
                </nav>

                <!-- Auth / Secret Key Section -->
                <div class="hidden md:block pt-6 border-t border-zinc-200/60 space-y-4">
                    <div>
                        <h2 class="text-[10px] font-bold uppercase tracking-widest text-zinc-400 pl-1">API KEY OTORISASI</h2>
                        <div class="relative mt-2">
                            <input type="password" id="adminSecret" placeholder="Input API Secret Key..."
                                class="w-full bg-zinc-50 border border-zinc-200 rounded-2xl py-3 pl-5 pr-12 text-xs text-zinc-800 outline-none focus:border-[#FBBF24] transition-all placeholder:text-zinc-450">
                            <button onclick="saveSecret()" class="absolute right-2.5 top-2 bg-gradient-to-r from-[#FBCA24] to-[#FBBF24] text-white p-2 rounded-xl active:scale-95 transition-all cursor-pointer shadow-sm">
                                <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                    <path d="M20 6L9 17l-5-5"/>
                                </svg>
                            </button>
                        </div>
                    </div>
                    <p id="secretStatus" class="text-[10px] text-[#FBBF24] font-extrabold hidden flex items-center gap-1.5 pl-1">
                        <span>✓</span> Otorisasi Lokal Aktif
                    </p>
                </div>
            </div>

            <!-- Footer / System Info -->
            <div class="hidden md:block space-y-4 pt-6 border-t border-zinc-200/60">
                <div class="flex items-center justify-between text-xs text-zinc-400">
                    <span>Host API:</span>
                    <span class="font-mono text-[10px] text-zinc-500">localhost:5000</span>
                </div>
                <a href="/admin/logout"
                    class="w-full block text-center py-3 border border-zinc-200 hover:border-red-500/20 hover:bg-red-500/10 text-xs text-zinc-500 hover:text-red-500 font-bold rounded-2xl transition-all cursor-pointer">
                    KELUAR PANEL
                </a>
            </div>
        </aside>

        <!-- Main Workspace -->
        <main class="flex-1 p-6 md:p-10 space-y-8 overflow-y-auto max-h-screen bg-[#F4F7FE]">
            
            <!-- Mobile Auth Trigger Alert -->
            <div class="md:hidden bg-white border border-zinc-200/60 rounded-2xl p-5 space-y-3">
                <div class="flex justify-between items-center">
                    <span class="text-[10px] font-bold uppercase tracking-wider text-zinc-400">OTORISASI API KEY</span>
                    <button onclick="saveSecretMobile()" class="bg-gradient-to-r from-[#FBCA24] to-[#FBBF24] text-white text-[10px] font-black px-4 py-1.5 rounded-xl transition-all cursor-pointer">SIMPAN</button>
                </div>
                <input type="password" id="adminSecretMobile" placeholder="Masukkan Secret Key..."
                    class="w-full bg-zinc-50 border border-zinc-200 rounded-2xl py-3 px-4 text-xs text-zinc-800 outline-none focus:border-[#FBBF24]">
            </div>

            <!-- Content Area -->
            <div class="space-y-6">

                <!-- TAB 1: DEVICE & AKTIVASI -->
                <div id="content-activation" class="space-y-6">
                    
                    <!-- Bento Grid Top Row -->
                    <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">
                        
                        <!-- Panel Cari User (Col-Span 3) -->
                        <div class="lg:col-span-3 bg-white rounded-3xl p-8 border border-zinc-200/50 flex flex-col justify-between min-h-[340px] relative overflow-hidden group shadow-sm">
                            <div class="space-y-5">
                                <div class="flex items-center justify-between">
                                    <h2 class="text-[10px] font-extrabold uppercase tracking-widest text-[#FBBF24]">STATUS & LISENSI USER</h2>
                                    <span class="w-2.5 h-2.5 rounded-full bg-[#FBBF24] animate-pulse"></span>
                                </div>
                                <p class="text-xs text-zinc-500 leading-relaxed max-w-xl">Masukkan WhatsApp UMKM terdaftar atau Serial Lisensi 6-digit untuk melihat daftar hardware yang terkunci, sisa durasi langganan, dan masa kadaluarsa.</p>
                                <div class="flex flex-col sm:flex-row gap-3 pt-2">
                                    <input type="text" id="phoneSearch" placeholder="No WhatsApp (08xxx) atau Serial Lisensi..."
                                        class="flex-1 bg-zinc-50 border border-zinc-200 rounded-2xl py-3.5 px-5 text-sm text-zinc-800 outline-none focus:border-[#FBBF24] transition-all placeholder:text-zinc-400">
                                    <button onclick="searchUser()"
                                        class="bg-gradient-to-r from-[#FBCA24] to-[#FBBF24] text-white font-black text-xs py-3.5 px-8 rounded-2xl transition-all cursor-pointer shadow-md active:scale-95">
                                        CEK USER
                                    </button>
                                </div>
                            </div>

                            <!-- Detail User Terpilih -->
                            <div id="userInfo" class="hidden border-t border-zinc-150 pt-6 mt-6 space-y-4">
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <div class="p-4 bg-zinc-50 rounded-2xl border border-zinc-200/50">
                                        <p class="text-[9px] text-zinc-450 uppercase font-bold tracking-wider">NAMA UMKM / PEMILIK</p>
                                        <p id="userName" class="text-sm font-black text-zinc-900 mt-1">-</p>
                                    </div>
                                    <div class="p-4 bg-zinc-50 rounded-2xl border border-zinc-200/50 flex justify-between items-center">
                                        <div>
                                            <p class="text-[9px] text-zinc-450 uppercase font-bold tracking-wider">HARDWARE TERDAFTAR</p>
                                            <p id="userDeviceCount" class="text-sm font-black text-zinc-900 mt-1">0 / 2</p>
                                        </div>
                                        <span class="text-[9px] bg-zinc-100 border border-zinc-200 text-zinc-500 py-1 px-2.5 rounded-lg font-bold">LIMIT 2</span>
                                    </div>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <div class="p-4 bg-zinc-50 rounded-2xl border border-zinc-200/50 flex justify-between items-center">
                                        <div>
                                            <p class="text-[9px] text-zinc-450 uppercase font-bold tracking-wider">STATUS LISENSI</p>
                                            <div class="mt-1" id="userCodeStatus">-</div>
                                        </div>
                                    </div>
                                    
                                    <!-- Masa Aktif Info -->
                                    <div id="expiryInfo" class="hidden p-4 bg-zinc-50 rounded-2xl border border-zinc-200/50 flex justify-between items-center gap-3">
                                        <div>
                                            <p class="text-[9px] text-zinc-450 uppercase font-bold tracking-wider">MASA BERLAKU AKTIVASI</p>
                                            <div id="expiryStatus" class="text-xs font-bold text-zinc-900 mt-1">-</div>
                                        </div>
                                        <button id="extendBtn" onclick="extendFromSearch()" 
                                            class="bg-gradient-to-r from-[#FBCA24] to-[#FBBF24] text-white px-3.5 py-2 rounded-xl font-black text-[10px] active:scale-95 transition-all cursor-pointer shadow-sm">
                                            +30 HARI
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Panel Set Aktivasi Manual (Col-Span 2) -->
                        <div class="lg:col-span-2 bg-white rounded-3xl p-8 border border-zinc-200/50 flex flex-col justify-between min-h-[340px] relative overflow-hidden shadow-sm">
                            <div class="space-y-4">
                                <h2 class="text-[10px] font-bold uppercase tracking-widest text-zinc-450">AKTIVASI MANUAL FORCE</h2>
                                <p class="text-xs text-zinc-500 leading-relaxed">Secara paksa menautkan WhatsApp UMKM dengan serial lisensi 6-digit kustom bypass pembayaran.</p>
                                
                                <div class="space-y-3 pt-2">
                                    <div class="space-y-1.5">
                                        <label class="text-[9px] font-bold text-zinc-450 uppercase tracking-wider pl-1">WHATSAPP TUJUAN</label>
                                        <input type="text" id="targetPhone" placeholder="Contoh: 08123456xxx"
                                            class="w-full bg-zinc-50 border border-zinc-200 rounded-2xl py-3 px-4 text-xs text-zinc-800 outline-none focus:border-[#FBBF24] transition-all placeholder:text-zinc-400">
                                    </div>
                                    <div class="space-y-1.5">
                                        <label class="text-[9px] font-bold text-zinc-450 uppercase tracking-wider pl-1">SERIAL KODE LISENSI</label>
                                        <div class="flex gap-2">
                                            <input type="text" id="newCode" placeholder="Masukkan 6-digit"
                                                class="flex-1 bg-zinc-50 border border-zinc-200 rounded-2xl py-3 px-4 text-xs text-zinc-800 outline-none focus:border-[#FBBF24] transition-all placeholder:text-zinc-400">
                                            <button onclick="genRandom()"
                                                class="bg-zinc-100 border border-zinc-200 text-zinc-650 hover:bg-zinc-200 px-4 rounded-2xl font-bold text-[10px] active:scale-95 transition-all cursor-pointer">
                                                RANDOM
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <button onclick="setActivation()"
                                class="w-full bg-zinc-900 hover:bg-zinc-800 text-white font-black text-xs py-4 rounded-2xl active:scale-[0.98] transition-all cursor-pointer shadow-sm mt-5 tracking-widest uppercase">
                                UPDATE KODE LISENSI
                            </button>
                        </div>

                    </div>

                    <!-- Devices Table -->
                    <div id="devicesSection" class="bg-white rounded-3xl p-8 border border-zinc-200/50 hidden shadow-sm">
                        <div class="flex items-center gap-2.5 mb-5 border-b border-zinc-150 pb-4">
                            <span class="w-2.5 h-2.5 rounded-full bg-[#FBBF24]"></span>
                            <h2 class="text-[10px] font-bold uppercase tracking-widest text-zinc-400">DAFTAR DEVICE HARDWARE TERKUNCI</h2>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse min-w-[550px]">
                                <thead>
                                    <tr class="text-[9px] text-zinc-400 uppercase tracking-widest font-black border-b border-zinc-200 pb-3">
                                        <th class="pb-3 pl-2">DEVICE ID (UNIQUE KEY)</th>
                                        <th class="pb-3">DEVICE MANUFACTURER (OS)</th>
                                        <th class="pb-3">WAKTU PENDAFTARAN</th>
                                        <th class="pb-3">AKTIVITAS TERAKHIR</th>
                                        <th class="pb-3 text-right pr-2">AKSI OTORISASI</th>
                                    </tr>
                                </thead>
                                <tbody id="deviceTableBody" class="divide-y divide-zinc-100 text-xs">
                                    <!-- Dynamic rows loaded here -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- TAB 2: ANTREAN BELI (PAYMENTS) -->
                <div id="content-payments" class="hidden space-y-6">
                    
                    <!-- Lunas Antrean -->
                    <div class="bg-white rounded-3xl p-8 border border-zinc-200/50 shadow-sm">
                        <div class="flex justify-between items-center mb-6 pb-4 border-b border-zinc-150">
                            <div class="flex items-center gap-3">
                                <span class="w-2.5 h-2.5 rounded-full bg-[#FBBF24] animate-ping"></span>
                                <h2 class="text-[10px] font-bold uppercase tracking-widest text-zinc-800">ANTREAN TRANSAKSI QRIS LUNAS</h2>
                            </div>
                            <button onclick="loadPayments()"
                                class="bg-zinc-50 border border-zinc-200 text-zinc-500 hover:text-zinc-800 px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-wider cursor-pointer transition-all active:scale-95">
                                REFRESH DATA ↻
                            </button>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse min-w-[650px]">
                                <thead>
                                    <tr class="text-[9px] text-zinc-400 uppercase tracking-widest font-black border-b border-zinc-200 pb-3">
                                        <th class="pb-3 pl-2">TANGGAL TRANSAKSI</th>
                                        <th class="pb-3">DETAIL ENTITAS UMKM & OWNER</th>
                                        <th class="pb-3">NOMOR WHATSAPP</th>
                                        <th class="pb-3">PLAN LAYANAN</th>
                                        <th class="pb-3 text-right pr-2">AKSI PROSES</th>
                                    </tr>
                                </thead>
                                <tbody id="paymentTableBody" class="divide-y divide-zinc-100 text-xs">
                                    <tr>
                                        <td colspan="5" class="py-8 text-center text-zinc-400">Mengambil data transaksi lunas...</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- QRIS Pending Antrean -->
                    <div class="bg-white rounded-3xl p-8 border border-zinc-200/50 shadow-sm">
                        <div class="flex items-center gap-2.5 mb-6 pb-4 border-b border-zinc-150">
                            <span class="w-2 h-2 rounded-full bg-zinc-300"></span>
                            <h2 class="text-[10px] font-bold uppercase tracking-widest text-zinc-400">SESI QRIS MENUNGGU PEMBAYARAN (PENDING)</h2>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse min-w-[550px]">
                                <thead>
                                    <tr class="text-[9px] text-zinc-400 uppercase tracking-widest font-black border-b border-zinc-200 pb-3">
                                        <th class="pb-3 pl-2">WAKTU TRANSAKSI</th>
                                        <th class="pb-3">NAMA UMKM / PEMILIK</th>
                                        <th class="pb-3">NOMOR WHATSAPP</th>
                                        <th class="pb-3">STATUS VERIFIKASI</th>
                                    </tr>
                                </thead>
                                <tbody id="pendingTableBody" class="divide-y divide-zinc-100 text-xs">
                                    <!-- Dynamic rows loaded here -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- TAB 3: LIST USER -->
                <div id="content-users" class="hidden space-y-6">
                    <div class="bg-white rounded-3xl p-8 border border-zinc-200/50 shadow-sm">
                        <div class="flex justify-between items-center mb-6 pb-4 border-b border-zinc-150">
                            <div>
                                <h2 class="text-[10px] font-bold uppercase tracking-widest text-zinc-400">DATABASE USER UTAMA</h2>
                            </div>
                            <div class="flex gap-3 items-center">
                                <button onclick="openUserModal()"
                                    class="bg-gradient-to-r from-[#FBCA24] to-[#FBBF24] text-white px-5 py-2.5 rounded-2xl font-black text-[10px] active:scale-[0.98] transition-all cursor-pointer uppercase tracking-widest shadow-md">
                                    + BUAT USER
                                </button>
                                <button onclick="loadUsers()"
                                    class="bg-zinc-50 border border-zinc-200 text-zinc-500 hover:text-zinc-800 px-4 py-2 rounded-xl text-[10px] font-bold cursor-pointer transition-all active:scale-95">
                                    REFRESH ↻
                                </button>
                            </div>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse min-w-[800px]">
                                <thead>
                                    <tr class="text-[9px] text-zinc-400 uppercase tracking-widest font-black border-b border-zinc-200 pb-3">
                                        <th class="pb-3 pl-2">ENTITAS / NAMA LENGKAP</th>
                                        <th class="pb-3">WHATSAPP</th>
                                        <th class="pb-3">SERIAL KODE LISENSI</th>
                                        <th class="pb-3">TGL KEDALUWARSA</th>
                                        <th class="pb-3 text-right pr-2">OPERASI DATA</th>
                                    </tr>
                                </thead>
                                <tbody id="userTableBody" class="divide-y divide-zinc-100 text-xs">
                                    <tr>
                                        <td colspan="5" class="py-8 text-center text-zinc-400">Memuat database consignor...</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

            </div>
        </main>
    </div>

    <!-- Modals & Overlay System -->

    <!-- Add/Edit User Modal -->
    <div id="userModal"
        class="fixed inset-0 bg-zinc-950/40 backdrop-blur-sm flex items-center justify-center hidden z-50 p-4 transition-all duration-300">
        <div class="bg-white rounded-3xl p-8 max-w-lg w-full shadow-2xl space-y-6 transform scale-95 opacity-0 transition-all duration-300 border border-zinc-150"
            id="userBox">
            <div class="flex justify-between items-center pb-4 border-b border-zinc-100">
                <h3 id="userModalTitle" class="text-sm font-black text-zinc-900 uppercase tracking-wider">Tambah User Baru</h3>
                <button onclick="closeUserModal()" class="text-zinc-400 hover:text-zinc-800 transition-colors cursor-pointer p-1.5 rounded-xl hover:bg-zinc-50">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            </div>
            
            <form id="userForm" class="space-y-4 text-left overflow-y-auto max-h-[60vh] pr-1">
                <input type="hidden" id="editUserId">
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="space-y-1.5">
                        <label class="text-[9px] font-bold text-zinc-500 uppercase tracking-wider pl-1">Nama Lengkap</label>
                        <input type="text" id="userFullName" required class="w-full bg-zinc-50 border border-zinc-200 rounded-2xl py-3 px-4 text-xs outline-none focus:border-[#FBBF24] transition-all">
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[9px] font-bold text-zinc-500 uppercase tracking-wider pl-1">WhatsApp (08xxx)</label>
                        <input type="text" id="userPhone" required class="w-full bg-zinc-50 border border-zinc-200 rounded-2xl py-3 px-4 text-xs outline-none focus:border-[#FBBF24] transition-all">
                    </div>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="space-y-1.5">
                        <label class="text-[9px] font-bold text-zinc-500 uppercase tracking-wider pl-1">Email</label>
                        <input type="email" id="userEmail" class="w-full bg-zinc-50 border border-zinc-200 rounded-2xl py-3 px-4 text-xs outline-none focus:border-[#FBBF24] transition-all">
                    </div>
                    <div class="space-y-1.5">
                        <label class="text-[9px] font-bold text-zinc-500 uppercase tracking-wider pl-1">Nama Toko / UMKM</label>
                        <input type="text" id="userStore" class="w-full bg-zinc-50 border border-zinc-200 rounded-2xl py-3 px-4 text-xs outline-none focus:border-[#FBBF24] transition-all">
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label id="passLabel" class="text-[9px] font-bold text-zinc-500 uppercase tracking-wider pl-1">Password</label>
                    <input type="password" id="userPassword" class="w-full bg-zinc-50 border border-zinc-200 rounded-2xl py-3 px-4 text-xs outline-none focus:border-[#FBBF24] transition-all" placeholder="Kosongkan jika tidak ingin ganti">
                </div>

                <div class="space-y-1.5">
                    <label class="text-[9px] font-bold text-zinc-500 uppercase tracking-wider pl-1">Modal Awal Toko (Rupiah)</label>
                    <input type="number" id="userCapital" class="w-full bg-zinc-50 border border-zinc-200 rounded-2xl py-3 px-4 text-xs outline-none focus:border-[#FBBF24] transition-all" value="0">
                </div>
            </form>

            <div class="flex gap-3 pt-4 border-t border-zinc-100">
                <button onclick="closeUserModal()"
                    class="flex-1 bg-zinc-50 border border-zinc-200 hover:bg-zinc-100 text-zinc-500 font-bold py-3.5 rounded-2xl transition-all cursor-pointer text-xs uppercase tracking-wider">
                    Batal
                </button>
                <button onclick="saveUser()"
                    class="flex-1 bg-gradient-to-r from-[#FBCA24] to-[#FBBF24] text-white font-black py-3.5 rounded-2xl active:scale-[0.98] transition-all cursor-pointer shadow-sm text-xs uppercase tracking-wider">
                    Simpan User
                </button>
            </div>
        </div>
    </div>

    <!-- Status Modal (Success Processing Payment) -->
    <div id="processingModal"
        class="fixed inset-0 bg-zinc-950/40 backdrop-blur-sm flex items-center justify-center hidden z-50 p-4">
        <div class="bg-white rounded-3xl p-8 max-w-sm w-full shadow-2xl space-y-6 text-center border border-zinc-150">
            <div class="w-16 h-16 bg-[#FBBF24]/10 text-[#FBBF24] rounded-2xl mx-auto flex items-center justify-center">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"
                    stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12" />
                </svg>
            </div>
            <div>
                <h3 class="text-sm font-black text-zinc-900 uppercase tracking-wider">UMKM Berhasil Diproses!</h3>
                <p class="text-xs text-zinc-500 mt-1">Akun consignor dibuat otomatis dan serial lisensi di-set.</p>
            </div>
            <div class="bg-zinc-50 border border-zinc-200/60 rounded-2xl p-5 space-y-1.5">
                <p class="text-[9px] font-bold text-zinc-400 uppercase tracking-wider">KODE LISENSI AKTIVASI</p>
                <p id="processedCode" class="text-3xl font-black text-zinc-950 tracking-widest">------</p>
            </div>
            <div class="text-left bg-zinc-50 border border-zinc-200/60 rounded-2xl p-5 space-y-2 text-xs">
                <p class="flex justify-between"><strong>Email:</strong> <span id="processedEmail" class="font-bold text-zinc-800"></span></p>
                <p class="flex justify-between"><strong>Password:</strong> <span class="bg-zinc-100 border border-zinc-200 px-2 py-0.5 rounded font-mono font-bold text-zinc-800">jitu1234</span></p>
            </div>
            <button onclick="closeModal()"
                class="w-full bg-gradient-to-r from-[#FBCA24] to-[#FBBF24] text-white font-black py-4 rounded-2xl transition-all cursor-pointer text-xs uppercase tracking-wider">
                Tutup Window
            </button>
        </div>
    </div>

    <!-- Custom Alert Modal -->
    <div id="alertModal"
        class="fixed inset-0 bg-zinc-950/40 backdrop-blur-sm flex items-center justify-center hidden z-[100] p-4">
        <div class="bg-white rounded-3xl p-8 max-w-sm w-full shadow-2xl space-y-6 text-center transform scale-95 opacity-0 transition-all duration-300 border border-zinc-150"
            id="alertBox">
            <div id="alertIcon" class="w-14 h-14 rounded-2xl mx-auto flex items-center justify-center">
                <!-- Dynamic SVG icon -->
            </div>
            <div>
                <h3 id="alertTitle" class="text-sm font-black text-zinc-900 uppercase tracking-wider">Judul</h3>
                <p id="alertMsg" class="text-xs text-zinc-500 mt-2 leading-relaxed">Pesan status sistem.</p>
            </div>
            <button onclick="closeAlert()"
                class="w-full bg-zinc-900 hover:bg-zinc-800 text-white font-bold py-3.5 rounded-2xl transition-all cursor-pointer text-xs uppercase tracking-wider">
                Mengerti
            </button>
        </div>
    </div>

    <!-- Custom Confirm Modal -->
    <div id="confirmModal"
        class="fixed inset-0 bg-zinc-950/40 backdrop-blur-sm flex items-center justify-center hidden z-[100] p-4">
        <div class="bg-white rounded-3xl p-8 max-w-sm w-full shadow-2xl space-y-6 text-center transform scale-95 opacity-0 transition-all duration-300 border border-zinc-150"
            id="confirmBox">
            <div class="w-14 h-14 bg-amber-500/10 text-amber-500 rounded-2xl mx-auto flex items-center justify-center border border-amber-500/20">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                    stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="12" y1="8" x2="12" y2="12" />
                    <line x1="12" y1="16" x2="12.01" y2="16" />
                </svg>
            </div>
            <div>
                <h3 id="confirmTitle" class="text-sm font-black text-zinc-900 uppercase tracking-wider">Konfirmasi Aksi</h3>
                <p id="confirmMsg" class="text-xs text-zinc-500 mt-2 leading-relaxed">Apakah anda sangat yakin?</p>
            </div>
            <div class="flex gap-3">
                <button id="confirmCancel"
                    class="flex-1 bg-zinc-50 border border-zinc-200 hover:bg-zinc-100 text-zinc-500 font-bold py-3.5 rounded-2xl transition-all cursor-pointer text-xs uppercase tracking-wider">
                    Batal
                </button>
                <button id="confirmOk"
                    class="flex-1 bg-red-500 hover:bg-red-650 text-white font-bold py-3.5 rounded-2xl transition-all cursor-pointer shadow-sm text-xs uppercase tracking-wider">
                    Ya, Yakin
                </button>
            </div>
        </div>
    </div>

    <!-- Toast Notification -->
    <div id="mainStatus"
        class="fixed bottom-10 right-10 max-w-sm w-full p-4 rounded-xl shadow-2xl translate-y-20 transition-all duration-300 opacity-0 pointer-events-none z-50 text-xs font-semibold">
        -
    </div>

    <script>
        const API = 'http://localhost:5000/api';

        // --- Custom Modal System ---
        function showAlert(title, msg, type = 'info') {
            const modal = document.getElementById('alertModal');
            const box = document.getElementById('alertBox');
            const icon = document.getElementById('alertIcon');

            document.getElementById('alertTitle').innerText = title;
            document.getElementById('alertMsg').innerText = msg;

            if (type === 'error') {
                icon.className = "w-14 h-14 bg-red-50 text-red-500 rounded-2xl mx-auto flex items-center justify-center border border-red-200";
                icon.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>';
            } else {
                icon.className = "w-14 h-14 bg-amber-50 text-amber-500 rounded-2xl mx-auto flex items-center justify-center border border-amber-200";
                icon.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>';
            }

            modal.classList.remove('hidden');
            setTimeout(() => {
                box.classList.remove('scale-95', 'opacity-0');
                box.classList.add('scale-100', 'opacity-100');
            }, 10);
        }

        function closeAlert() {
            const modal = document.getElementById('alertModal');
            const box = document.getElementById('alertBox');
            box.classList.add('scale-95', 'opacity-0');
            setTimeout(() => modal.classList.add('hidden'), 300);
        }

        function showConfirm(title, msg) {
            return new Promise((resolve) => {
                const modal = document.getElementById('confirmModal');
                const box = document.getElementById('confirmBox');
                const okBtn = document.getElementById('confirmOk');
                const cancelBtn = document.getElementById('confirmCancel');

                document.getElementById('confirmTitle').innerText = title;
                document.getElementById('confirmMsg').innerText = msg;

                const cleanup = (val) => {
                    box.classList.add('scale-95', 'opacity-0');
                    setTimeout(() => modal.classList.add('hidden'), 300);
                    resolve(val);
                };

                okBtn.onclick = () => cleanup(true);
                cancelBtn.onclick = () => cleanup(false);

                modal.classList.remove('hidden');
                setTimeout(() => {
                    box.classList.remove('scale-95', 'opacity-0');
                    box.classList.add('scale-100', 'opacity-100');
                }, 10);
            });
        }

        function showStatus(msg, err = false) {
            const el = document.getElementById('mainStatus');
            el.innerText = msg;
            el.className = `fixed bottom-10 right-10 max-w-sm w-full p-4 rounded-xl shadow-2xl transition-all duration-300 ${err ? 'bg-red-500 text-white shadow-red-500/10' : 'bg-zinc-900 text-[#FFCA40] font-black'}`;
            el.classList.remove('opacity-0', 'translate-y-20');
            el.classList.add('opacity-100', 'translate-y-0');
            setTimeout(() => {
                el.classList.add('opacity-0', 'translate-y-20');
                el.classList.remove('opacity-100', 'translate-y-0');
            }, 3000);
        }

        function switchTab(tab) {
            // Hide all contents
            document.getElementById('content-activation').classList.add('hidden');
            document.getElementById('content-payments').classList.add('hidden');
            document.getElementById('content-users').classList.add('hidden');

            // Inactive all tabs
            const tabs = ['activation', 'payments', 'users'];
            tabs.forEach(t => {
                const btn = document.getElementById(`tab-${t}`);
                btn.className = "w-auto md:w-full text-left py-3.5 px-5 rounded-2xl text-xs font-black uppercase tracking-wider text-zinc-400 hover:text-zinc-800 hover:bg-zinc-100 transition-all duration-200 flex items-center gap-3.5 cursor-pointer whitespace-nowrap";
            });

            // Activate current
            document.getElementById(`content-${tab}`).classList.remove('hidden');
            const currentTab = document.getElementById(`tab-${tab}`);
            currentTab.className = "w-auto md:w-full text-left py-3.5 px-5 rounded-2xl text-xs font-black uppercase tracking-wider transition-all duration-200 flex items-center gap-3.5 cursor-pointer whitespace-nowrap bg-gradient-to-r from-[#FBCA24] to-[#FBBF24] text-white shadow-md";

            if (tab === 'payments') loadPayments();
            if (tab === 'users') loadUsers();
        }

        async function api(path, method = 'GET', body = null) {
            const secret = localStorage.getItem('jitu_admin_secret');
            if (!secret) throw new Error('Simpan Admin Secret Key terlebih dahulu');

            const options = {
                method,
                headers: {
                    'Content-Type': 'application/json',
                    'x-admin-secret': secret
                }
            };
            if (body) options.body = JSON.stringify(body);

            const res = await fetch(`${API}${path}`, options);
            const data = await res.json();
            if (!data.success) throw new Error(data.message || 'API Error');
            return data;
        }

        // Track phone for extend from search
        let currentSearchPhone = null;

        // Activation Logic
        async function searchUser(searchParam = null) {
            const searchStr = searchParam || document.getElementById('phoneSearch').value;
            if (!searchStr) return showAlert('Validasi', 'Masukkan nomor telepon atau kode lisensi terlebih dahulu.');
            
            // Jika pencarian dipicu dari Set Activation, sinkronkan input cari
            if (searchParam) document.getElementById('phoneSearch').value = searchParam;
            currentSearchPhone = searchStr;

            try {
                const data = await api('/admin/user-details', 'POST', { searchStr });
                document.getElementById('userInfo').classList.remove('hidden');
                document.getElementById('userName').innerText = data.user.full_name;
                document.getElementById('userCodeStatus').innerText = data.user.has_activation ? 'AKTIF' : 'BELUM SET';
                document.getElementById('userCodeStatus').className = `inline-block px-3 py-1 rounded-xl text-[10px] font-bold ${data.user.has_activation ? 'bg-[#FBBF24]/10 text-amber-600 border border-[#FBBF24]/20' : 'bg-red-50 text-red-500 border border-red-200'}`;
                
                const deviceCountText = `${data.devices.length} / 2`;
                const deviceCountEl = document.getElementById('userDeviceCount');
                deviceCountEl.innerText = deviceCountText;
                if (data.devices.length >= 2) {
                    deviceCountEl.className = 'text-sm font-bold text-red-500';
                } else {
                    deviceCountEl.className = 'text-sm font-bold text-zinc-900';
                }

                document.getElementById('targetPhone').value = data.user.phone;
                renderDevices(data.devices);

                // Show expiry info
                const expiryDiv = document.getElementById('expiryInfo');
                const expiryStatus = document.getElementById('expiryStatus');
                expiryDiv.classList.remove('hidden');

                if (!data.user.activation_set_at) {
                    expiryDiv.className = 'p-4 bg-zinc-50 rounded-2xl border border-zinc-200/50 flex justify-between items-center gap-3';
                    expiryStatus.innerHTML = '<span class="text-zinc-400">Belum pernah diaktifkan</span>';
                } else if (data.user.is_expired) {
                    expiryDiv.className = 'p-4 bg-red-50 rounded-2xl border border-red-200 flex justify-between items-center gap-3';
                    expiryStatus.innerHTML = '<span class="text-red-500 font-bold">⚠ Kadaluarsa</span> <span class="text-[10px] text-red-400 block">sejak ' + new Date(data.user.expires_at).toLocaleDateString() + '</span>';
                } else {
                    const exp = new Date(data.user.expires_at);
                    const daysLeft = Math.ceil((exp - new Date()) / (1000 * 60 * 60 * 24));
                    expiryDiv.className = 'p-4 bg-amber-50 rounded-2xl border border-[#FBBF24]/20 flex justify-between items-center gap-3';
                    expiryStatus.innerHTML = `<span class="text-amber-800 font-bold">${daysLeft} hari tersisa</span> <span class="text-[10px] text-[#FBBF24] block font-semibold">s/d ${exp.toLocaleDateString()}</span>`;
                }
            } catch (err) {
                showAlert('Gagal', err.message, 'error');
                document.getElementById('userInfo').classList.add('hidden');
                document.getElementById('devicesSection').classList.add('hidden');
                document.getElementById('expiryInfo').classList.add('hidden');
            }
        }

        // Extend activation from search panel
        async function extendFromSearch() {
            if (!currentSearchPhone) return;
            await extendActivation(currentSearchPhone);
            searchUser(currentSearchPhone);
        }

        // Extend activation (reusable)
        async function extendActivation(phone, days = 30) {
            const confirmed = await showConfirm('Perpanjang Masa Aktif', `Perpanjang masa aktif user ini sebanyak ${days} hari?`);
            if (!confirmed) return;
            try {
                const data = await api('/admin/extend-activation', 'POST', { phone, days });
                showStatus(data.message);
                // Refresh list jika di tab users
                if (!document.getElementById('content-users').classList.contains('hidden')) {
                    loadUsers();
                }
            } catch (err) {
                showAlert('Gagal Perpanjang', err.message, 'error');
            }
        }

        function renderDevices(devices) {
            const section = document.getElementById('devicesSection');
            const tbody = document.getElementById('deviceTableBody');
            tbody.innerHTML = '';
            if (devices.length === 0) { section.classList.add('hidden'); return; }
            section.classList.remove('hidden');
            devices.forEach(d => {
                tbody.innerHTML += `
                    <tr class="border-b border-zinc-100 hover:bg-zinc-50/50 text-zinc-650">
                        <td class="py-4 pl-2 font-mono text-[11px] text-zinc-400">${d.device_id.slice(0, 10)}...</td>
                        <td class="py-4 font-bold text-zinc-800">${d.device_name || '-'}</td>
                        <td class="py-4 text-zinc-500">${new Date(d.activated_at).toLocaleString()}</td>
                        <td class="py-4 text-zinc-500">${new Date(d.last_used_at).toLocaleString()}</td>
                        <td class="py-4 text-right pr-2">
                            <button onclick="deleteDevice(${d.id})" class="bg-red-50 hover:bg-red-100 text-red-500 px-3 py-1.5 rounded-xl font-bold text-[10px] border border-red-200 transition-all cursor-pointer">HAPUS</button>
                        </td>
                    </tr>
                `;
            });
        }

        async function deleteDevice(id) {
            const confirmed = await showConfirm('Konfirmasi Hapus', 'Apa Anda yakin ingin menghapus device ini? User harus aktivasi ulang jika ingin menggunakan device ini lagi.');
            if (!confirmed) return;
            try {
                await api(`/admin/devices/${id}`, 'DELETE');
                showStatus('Device dihapus');
                searchUser();
            } catch (err) { showAlert('Error', err.message, 'error'); }
        }

        function genRandom() { document.getElementById('newCode').value = Math.floor(100000 + Math.random() * 900000); }

        async function setActivation() {
            const phone = document.getElementById('targetPhone').value;
            const code = document.getElementById('newCode').value;
            if (!phone || !code) return showAlert('Input Kosong', 'Nomor telepon dan kode aktivasi wajib diisi.');
            try {
                await api('/admin/set-activation', 'POST', { phone, activation_code: code });
                showStatus('Kode Aktivasi disimpan!');
                searchUser(phone);
            } catch (err) { showAlert('Gagal Simpan', err.message, 'error'); }
        }

        // List Users Logic
        async function loadUsers() {
            const tbody = document.getElementById('userTableBody');
            try {
                const data = await api('/admin/users');
                tbody.innerHTML = '';
                if (data.users.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="5" class="py-8 text-center text-zinc-400">Belum ada user yang terdaftar.</td></tr>';
                    return;
                }
                data.users.forEach(u => {
                    let statusBadge;
                    if (!u.activation_set_at) {
                        statusBadge = '<span class="px-2.5 py-0.5 bg-zinc-50 text-zinc-400 rounded-full text-[10px] font-bold border border-zinc-200">BELUM SET</span>';
                    } else if (u.is_expired) {
                        statusBadge = '<span class="px-2.5 py-0.5 bg-red-50 text-red-500 rounded-full text-[10px] font-bold border border-red-200">KADALUARSA</span>';
                    } else {
                        const exp = new Date(u.expires_at);
                        const now = new Date();
                        const daysLeft = Math.ceil((exp - now) / (1000 * 60 * 60 * 24));
                        statusBadge = `<span class="px-2.5 py-0.5 ${daysLeft <= 7 ? 'bg-amber-50 text-amber-600 border border-amber-200' : 'bg-[#FBBF24]/10 text-amber-800 border border-[#FBBF24]/20'} rounded-full text-[10px] font-bold">${daysLeft} HARI LAGI</span>`;
                    }

                    tbody.innerHTML += `
                        <tr class="border-b border-zinc-100 hover:bg-zinc-50/40 text-zinc-600">
                            <td class="py-4 pl-2">
                                <div class="font-bold text-zinc-800 text-sm">${u.full_name}</div>
                                <div class="text-[10px] text-zinc-400 font-mono">ID: ${u.consignor_id}</div>
                            </td>
                            <td class="py-4 font-bold text-sm">
                                <a href="https://wa.me/${formatWA(u.phone)}" target="_blank" class="text-amber-600 hover:underline">
                                    ${u.phone}
                                </a>
                            </td>
                            <td class="py-4 font-mono font-black text-amber-600 tracking-widest text-sm">${u.activation && u.activation.length <= 10 ? u.activation : '<span class="text-[10px] text-zinc-400 font-normal">TERENKRIPSI LAMA</span>'}</td>
                            <td class="py-4">
                                <div class="flex flex-col gap-0.5">
                                    <div>${statusBadge}</div>
                                    ${u.expires_at ? '<div class="text-[10px] text-zinc-400">s/d ' + new Date(u.expires_at).toLocaleDateString() + '</div>' : ''}
                                </div>
                            </td>
                            <td class="py-4 text-right pr-2">
                                <div class="flex gap-2.5 justify-end">
                                    <button onclick="extendActivation('${u.phone}')" 
                                        class="bg-[#FBBF24]/10 hover:bg-[#FBBF24]/20 text-amber-600 px-3 py-2 rounded-xl font-bold text-[10px] border border-[#FBBF24]/15 transition-all cursor-pointer">
                                        + 30 HARI
                                    </button>
                                    <button onclick="openUserModal(${u.consignor_id})" 
                                        class="bg-zinc-50 border border-zinc-200 text-zinc-500 hover:text-zinc-800 px-3 py-2 rounded-xl font-bold text-[10px] transition-all cursor-pointer">
                                        EDIT
                                    </button>
                                    <button onclick="deleteUser(${u.consignor_id})" 
                                        class="bg-red-50 hover:bg-red-100 border border-red-200 text-red-500 px-3 py-2 rounded-xl font-bold text-[10px] transition-all cursor-pointer">
                                        HAPUS
                                    </button>
                                </div>
                            </td>
                        </tr>
                    `;
                });
            } catch (err) {
                showAlert('Eror Load User', err.message, 'error');
            }
        }

        // Payment Logic
        async function loadPayments() {
            const tbody = document.getElementById('paymentTableBody');
            const pbody = document.getElementById('pendingTableBody');

            try {
                const data = await api('/admin/payments');
                const { ready, pending } = data.payments;

                tbody.innerHTML = '';
                if (ready.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="5" class="py-8 text-center text-zinc-400">Tidak ada antrean pembayaran lunas.</td></tr>';
                } else {
                    ready.forEach(p => {
                        tbody.innerHTML += `
                            <tr class="border-b border-zinc-100 hover:bg-zinc-50/40 text-zinc-600">
                                <td class="py-4 pl-2 text-zinc-400">${new Date(p.created_at).toLocaleDateString()}</td>
                                <td class="py-4">
                                    <div class="font-bold text-zinc-800 text-sm">${p.umkm}</div>
                                    <div class="text-[10px] text-zinc-400">${p.full_name}</div>
                                </td>
                                <td class="py-4 font-bold text-sm">
                                    <a href="https://wa.me/${formatWA(p.whatsapp)}" target="_blank" class="text-amber-600 hover:underline">
                                        ${p.whatsapp}
                                    </a>
                                </td>
                                <td class="py-4">
                                    <span class="px-3 py-1 bg-zinc-50 border border-zinc-200 rounded-full text-[10px] font-bold">PLAN ${p.plan || 1}</span>
                                </td>
                                <td class="py-4 text-right pr-2">
                                    <button onclick="processPayment('${p.id_payment}')" class="bg-gradient-to-r from-[#FBCA24] to-[#FBBF24] text-white px-4 py-2 rounded-2xl font-black text-[10px] transition-all cursor-pointer shadow-sm">PROSES UMKM</button>
                                </td>
                            </tr>
                        `;
                    });
                }

                pbody.innerHTML = '';
                if (pending.length === 0) {
                    pbody.innerHTML = '<tr><td colspan="4" class="py-6 text-center text-zinc-400">Tidak ada pembayaran tertunda.</td></tr>';
                } else {
                    pending.forEach(p => {
                        pbody.innerHTML += `
                            <tr class="border-b border-zinc-100 text-zinc-550 text-[11px]">
                                <td class="py-3.5 pl-2 text-zinc-400">${new Date(p.created_at).toLocaleDateString()}</td>
                                <td class="py-3.5 font-bold text-zinc-700">${p.umkm}</td>
                                <td class="py-3.5">
                                    <a href="https://wa.me/${formatWA(p.whatsapp)}" target="_blank" class="text-zinc-500 hover:text-amber-600 transition-colors">
                                        ${p.whatsapp}
                                    </a>
                                </td>
                                <td class="py-3.5 italic text-zinc-400 flex items-center gap-1.5">
                                    <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span> QRIS PENDING
                                </td>
                            </tr>
                        `;
                    });
                }
            } catch (err) {
                showAlert('Eror Load', err.message, 'error');
            }
        }

        function formatWA(num) {
            return num.replace(/^0/, '62');
        }

        async function processPayment(id) {
            const confirmed = await showConfirm('Proses UMKM', 'Sistem akan membuatkan akun dan men-set kode aktivasi untuk UMKM ini. Lanjutkan?');
            if (!confirmed) return;
            try {
                const data = await api('/admin/process-payment', 'POST', { id_payment: id });
                document.getElementById('processedCode').innerText = data.activation_code;
                document.getElementById('processedEmail').innerText = data.user.email;
                document.getElementById('processingModal').classList.remove('hidden');
                loadPayments();
            } catch (err) { showAlert('Error', err.message, 'error'); }
        }

        function closeModal() { document.getElementById('processingModal').classList.add('hidden'); }

        // Secret Section
        function saveSecret() {
            const secret = document.getElementById('adminSecret').value;
            if (!secret) return showAlert('Peringatan', 'Secret Key tidak boleh kosong.');
            localStorage.setItem('jitu_admin_secret', secret);
            document.getElementById('secretStatus').classList.remove('hidden');
            showStatus('Secret Key disimpan');
        }

        function saveSecretMobile() {
            const secret = document.getElementById('adminSecretMobile').value;
            if (!secret) return showAlert('Peringatan', 'Secret Key tidak boleh kosong.');
            localStorage.setItem('jitu_admin_secret', secret);
            showStatus('Secret Key disimpan');
        }

        document.getElementById('adminSecret').value = localStorage.getItem('jitu_admin_secret') || '';
        document.getElementById('adminSecretMobile').value = localStorage.getItem('jitu_admin_secret') || '';
        if (localStorage.getItem('jitu_admin_secret')) {
            document.getElementById('secretStatus').classList.remove('hidden');
        }

        // --- User CRUD Logic ---
        function openUserModal(userId = null) {
            const modal = document.getElementById('userModal');
            const box = document.getElementById('userBox');
            const form = document.getElementById('userForm');
            const title = document.getElementById('userModalTitle');
            const passLabel = document.getElementById('passLabel');

            form.reset();
            document.getElementById('editUserId').value = userId || '';

            if (userId) {
                title.innerText = 'Edit Data User';
                passLabel.innerText = 'Password Baru (Opsional)';
                const row = document.querySelector(`button[onclick="openUserModal(${userId})"]`).closest('tr');
                document.getElementById('userFullName').value = row.querySelector('.font-bold').innerText;
                document.getElementById('userPhone').value = row.querySelector('a').innerText.trim();
                document.getElementById('userEmail').value = row.cells[2].innerText.trim() === '-' ? '' : row.cells[2].innerText.trim();
                
                api(`/admin/user-details`, 'POST', { phone: row.querySelector('a').innerText.trim() })
                    .then(data => {
                        document.getElementById('userFullName').value = data.user.full_name;
                        document.getElementById('userPhone').value = data.user.phone;
                        document.getElementById('userEmail').value = data.user.email || '';
                    });
            } else {
                title.innerText = 'Tambah User Baru';
                passLabel.innerText = 'Password (Wajib)';
            }

            modal.classList.remove('hidden');
            setTimeout(() => {
                box.classList.remove('scale-95', 'opacity-0');
                box.classList.add('scale-100', 'opacity-100');
            }, 10);
        }

        function closeUserModal() {
            const modal = document.getElementById('userModal');
            const box = document.getElementById('userBox');
            box.classList.add('scale-95', 'opacity-0');
            setTimeout(() => modal.classList.add('hidden'), 300);
        }

        async function saveUser() {
            const id = document.getElementById('editUserId').value;
            const full_name = document.getElementById('userFullName').value;
            const phone = document.getElementById('userPhone').value;
            const email = document.getElementById('userEmail').value;
            const password = document.getElementById('userPassword').value;
            const store_name = document.getElementById('userStore').value;
            const total_capital = document.getElementById('userCapital').value;

            if (!full_name || !phone || (!id && !password)) {
                return showAlert('Validasi', 'Nama, Phone, dan Password (untuk user baru) wajib diisi.');
            }

            try {
                const method = id ? 'PUT' : 'POST';
                const path = id ? `/admin/users/${id}` : '/admin/users';
                const body = { full_name, phone, email, password, store_name, total_capital };
                
                const res = await api(path, method, body);
                showStatus(res.message);
                closeUserModal();
                loadUsers();
            } catch (err) {
                showAlert('Gagal Simpan', err.message, 'error');
            }
        }

        async function deleteUser(id) {
            const confirmed = await showConfirm('Hapus User', 'Apakah Anda yakin ingin menghapus user ini selamanya? Seluruh data device terkait juga akan dihapus.');
            if (!confirmed) return;

            try {
                const res = await api(`/admin/users/${id}`, 'DELETE');
                showStatus(res.message);
                loadUsers();
            } catch (err) {
                showAlert('Gagal Hapus', err.message, 'error');
            }
        }
    </script>
</body>

</html>